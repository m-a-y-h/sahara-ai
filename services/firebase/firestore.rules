rules_version = '2';
// Deploy:  firebase deploy --only firestore:rules
// Baseline that UNBLOCKS the app and locks personal data to its owner.
// Role-gated actions (admin approvals, counselor writes) are NOT yet enforced
// at this layer — see the TODO(custom-claims) notes. Add Firebase custom claims
// (the sahara_push Modal service already has the Admin SDK) to tighten them.
service cloud.firestore {
  match /databases/{database}/documents {

    // All per-user data (sleep_logs, sahara_lens_checkins, etc.): owner only.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Chat messages (flat collection, queried by sessionId). A list query can't be
    // participant-checked per document, so reads are gated to any signed-in user.
    // AI sessionId is "ai_<uid>". For TRUE privacy, move AI chat to
    // /users/{uid}/ai_messages (owner-locked) — ask and I'll refactor it.
    match /messages/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.data.senderId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);
    }

    // Directories: browsable by signed-in users; writes only via backend/admin.
    match /counselors/{id} { allow read: if request.auth != null; allow write: if false; }
    match /ngos/{id}       { allow read: if request.auth != null; allow write: if false; }

    // Shared collections — signed-in access. TODO(custom-claims): gate writes by role.
    match /reports/{id}          { allow read, write: if request.auth != null; }
    match /emergency_alerts/{id} { allow read, write: if request.auth != null; }
    match /community_posts/{id}  { allow read, write: if request.auth != null; }
    match /user_connections/{id} { allow read, write: if request.auth != null; }
    match /notifications/{id}    { allow read, write: if request.auth != null; }
    match /chat_sessions/{id}    { allow read, write: if request.auth != null; }

    // Everything else: deny.
    match /{document=**} { allow read, write: if false; }
  }
}
